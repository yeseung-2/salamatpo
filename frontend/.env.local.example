# Recommended for local dev (avoids CORS / mobile localhost issues via Next.js proxy)
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Optional: override proxy target if backend runs elsewhere
# API_PROXY_TARGET=http://localhost:8000

# Direct backend URL (only if you are NOT using the Next.js proxy)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1