# ── Local dev (Next.js proxy → localhost:8000) ──
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Optional: override proxy target if backend runs elsewhere
# API_PROXY_TARGET=http://localhost:8000

# ── Vercel production (set in Vercel dashboard, no trailing slash) ──
# NEXT_PUBLIC_API_BASE_URL=https://your-app.up.railway.app/api/v1

# ── Railway backend (set in Railway dashboard) ──
# FRONTEND_URL=https://salamatpo.vercel.app